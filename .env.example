# Dora-AI Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# Hedera Network
# ============================================
# Network: testnet or mainnet
HEDERA_NETWORK=testnet
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Operator account (pays HCS fees, deploys contracts)
# Create at: https://portal.hedera.com → Testnet → Create Account (ECDSA)
DORA_OPERATOR_ID=0.0.XXXXXXX
DORA_OPERATOR_KEY=3030020100301206072a8648ce...

# Dora-AI treasury account (receives payments)
DORA_TREASURY_ID=0.0.XXXXXXX

# HCS Topic IDs (create these via Hedera portal or SDK)
HCS_SEARCH_LOG_TOPIC=0.0.0
HCS_PRICE_LOG_TOPIC=0.0.0
HCS_PURCHASE_LOG_TOPIC=0.0.0

# ============================================
# Google Gemini (FREE — 1,500 requests/day, no credit card)
# ============================================
# Get key: https://aistudio.google.com/apikey
# This is the PRIMARY vision model. Free and high quality.
GEMINI_API_KEY=

# ============================================
# OpenAI GPT-4o (PAID — backup, better detail)
# ============================================
# Register: https://platform.openai.com/signup
# Get key:  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================
# Hugging Face (Open Source Vision — Optional)
# ============================================
# No key needed! Uses free inference API by default.
# Get optional token for higher rate limits:
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ============================================
# Pinecone (Vector Database)
# ============================================
# Register: https://www.pinecone.io
# Create index: dimensions=1536, metric=cosine
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=dora-products

# ============================================
# Pinata (IPFS Storage)
# ============================================
# Register: https://app.pinata.cloud/register
# Get JWT:  https://app.pinata.cloud/developers/api-keys
PINATA_JWT=...
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
